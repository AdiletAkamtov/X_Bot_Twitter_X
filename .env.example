# Xauro — Environment Variable Template
# Never commit .env to version control.

# ── Security ──
ENCRYPTION_KEY=your_fernet_key_here

# ── Database ──
DB_PATH=data/xauro.db

# ── AI Providers ──
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
GROQ_API_KEY=
DEFAULT_AI_PROVIDER=groq

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# ── Logging ──
LOG_LEVEL=INFO
